# Copy this file to .env and update values before running the app
# For Gmail, use an App Password and do not use your normal login password.
SECRET_KEY=change-me-to-a-secure-value
DATABASE_URL=sqlite:///capa.db
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@example.com
